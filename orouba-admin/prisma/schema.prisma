// This is your Prisma schema file
// Configured for PostgreSQL on a VPS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Users & Authentication
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(USER)
  permissions   String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders    Order[]
  cartItems CartItem[]
}

enum Role {
  USER
  ADMIN
  EDITOR
}

// -----------------------------------------------------------------------------
// Main Entities (Brands, Categories, Products)
// -----------------------------------------------------------------------------

model Brand {
  id             String   @id @default(cuid())
  nameEn         String
  nameAr         String
  number         Int      @default(999)
  image          String? // maps to image
  imageMain      String? // maps to imageMain / imageBrand
  imageSmall     String?
  imageSmallMain String?
  colorBrand     String?
  colorHover     String?
  descriptionEn  String?  @db.Text
  descriptionAr  String?  @db.Text
  isHidden       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categories Category[]

  @@index([isHidden])
}

model CategoryType {
  id            String   @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  number        Int      @default(999)
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categories CategoryTypeCategory[]

  @@index([isHidden])
}

model Category {
  id            String  @id @default(cuid())
  nameEn        String
  nameAr        String
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  image         String?
  imageEn       String?
  number        Int     @default(999)
  isHidden      Boolean @default(false)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      CategoryProduct[]
  categoryTypes CategoryTypeCategory[]

  @@index([isHidden])
  @@index([brandId])
}

model CategoryTypeCategory {
  id             String  @id @default(cuid())
  categoryId     String
  categoryTypeId String
  image          String?
  number         Int     @default(999)

  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryType CategoryType @relation(fields: [categoryTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, categoryTypeId])
}

model ProductType {
  id        String   @id @default(cuid())
  nameEn    String
  nameAr    String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([isHidden])
}

model Product {
  id            String  @id @default(cuid())
  nameEn        String
  nameAr        String
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  color         String  @default("#ffffff")
  number        Int     @default(999)
  isHidden      Boolean @default(false)

  typeId String?
  type   ProductType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images             ProductImage[]
  categories         CategoryProduct[]
  recommendedRecipes RecommendedRecipe[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  socials            ProductSocial[]

  @@index([isHidden])
  @@index([typeId])
}

model CategoryProduct {
  id         String  @id @default(cuid())
  categoryId String
  productId  String
  isHidden   Boolean @default(false)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, productId])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Recipes & Food (Cooks)
// -----------------------------------------------------------------------------

model RecipeCategory {
  id       String  @id @default(cuid())
  nameEn   String
  nameAr   String
  image    String?
  number   Int     @default(999)
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  foods RecipeCategoryFood[]
}

model Recipe {
  id            String  @id @default(cuid())
  nameEn        String?
  nameAr        String?
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  videoLink     String? @db.Text
  internalImage String? @db.Text
  number        Int     @default(999)
  isHidden      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images          RecipeImage[]
  properties      RecipeProperty[]
  steps           RecipeStep[]
  foods           RecipeFood[]
  recommendedWith RecommendedRecipe[]

  @@index([isHidden])
}

model RecipeImage {
  id       String @id @default(cuid())
  recipeId String
  url      String @db.Text

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeProperty {
  id       String  @id @default(cuid())
  recipeId String
  icon     String?
  titleEn  String
  titleAr  String
  textEn   String
  textAr   String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeStep {
  id       String @id @default(cuid())
  recipeId String
  stepEn   String @db.Text
  stepAr   String @db.Text

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Food {
  id       String  @id @default(cuid())
  nameEn   String?
  nameAr   String?
  image    String?
  number   Int     @default(999)
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes          RecipeFood[]
  recipeCategories RecipeCategoryFood[]

  @@index([isHidden])
}

model RecipeFood {
  id       String @id @default(cuid())
  recipeId String
  foodId   String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recipeId, foodId])
}

model RecipeCategoryFood {
  id               String @id @default(cuid())
  recipeCategoryId String
  foodId           String

  recipeCategory RecipeCategory @relation(fields: [recipeCategoryId], references: [id], onDelete: Cascade)
  food           Food           @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([recipeCategoryId, foodId])
}

model RecommendedRecipe {
  id        String @id @default(cuid())
  productId String
  recipeId  String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, recipeId])
}

// -----------------------------------------------------------------------------
// Site Content & Marketing
// -----------------------------------------------------------------------------

model Banner {
  id           String     @id @default(cuid())
  titleEn      String
  titleAr      String
  type         BannerType @default(image)
  image        String?
  imageEn      String?
  videoLink    String?
  videoLinkEn  String?
  smallImg     String?
  smallImgEn   String?
  smallVideo   String?
  smallVideoEn String?
  number       Int        @default(999)
  isHidden     Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isHidden])
}

enum BannerType {
  image
  video
}

model Certificate {
  id        String   @id @default(cuid())
  image     String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Standard {
  id            String   @id @default(cuid())
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Value {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhyChooseUs {
  id            String   @id @default(cuid())
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Building {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Feature {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?  @db.Text
  descriptionAr String?  @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductionStep {
  id        String   @id @default(cuid())
  textEn    String   @db.Text
  textAr    String   @db.Text
  number    Int      @default(999)
  image     String?
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionText {
  id        String   @id @default(cuid())
  titleEn   String?
  titleAr   String?
  textEn    String?  @db.Text
  textAr    String?  @db.Text
  number    Int      @default(999)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  image     String?
  link      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialParent {
  id        String   @id @default(cuid())
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSocial {
  id        String   @id @default(cuid())
  image     String?
  productId String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEn     String?  @db.Text
  valueAr     String?  @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Geography
// -----------------------------------------------------------------------------

model Continent {
  id        String   @id @default(cuid())
  nameEn    String?
  nameAr    String?
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  countries Country[]
}

model Country {
  id          String   @id @default(cuid())
  nameEn      String?
  nameAr      String?
  continentId String
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  continent Continent @relation(fields: [continentId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Lead Generation (Forms)
// -----------------------------------------------------------------------------

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?       @db.Text
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CareerRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  position  String?
  message   String?       @db.Text
  resumeUrl String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CollaborateRequest {
  id        String        @id @default(cuid())
  firstName String?
  lastName  String?
  name      String?
  email     String
  phone     String?
  message   String?       @db.Text
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

enum RequestStatus {
  UNREAD
  READ
  ARCHIVED
}

// -----------------------------------------------------------------------------
// B2B Inquiry Models
// -----------------------------------------------------------------------------

model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, productId])
}

model Order {
  id          String      @id @default(cuid())
  userId      String?
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float  @default(0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// -----------------------------------------------------------------------------
// System
// -----------------------------------------------------------------------------

model SystemLog {
  id        String   @id @default(cuid())
  userId    String? // Might map to Admin ID
  action    String?
  date      String?
  ip        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Popups Manager
// -----------------------------------------------------------------------------

model Popup {
  id               String   @id @default(cuid())
  internalName     String
  titleEn          String?
  titleAr          String?
  contentEn        String?  @db.Text
  contentAr        String?  @db.Text
  image            String?

  // Style & Animation
  type             String   @default("MODAL")
  animation        String   @default("FADE")
  backgroundColor  String   @default("#ffffff")
  textColor        String   @default("#000000")
  overlayColor     String   @default("rgba(0,0,0,0.5)")
  borderRadius     Int      @default(16)
  maxWidth         Int      @default(500)

  // Custom Buttons – JSON array
  buttons          Json?

  // Trigger
  trigger          String   @default("ON_LOAD")
  triggerValue     Int      @default(0)

  // Advanced Conditions – JSON object
  conditions       Json?

  // Scheduling & Status
  isActive         Boolean  @default(false)
  priority         Int      @default(0)
  startDate        DateTime?
  endDate          DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Chat Widget
// -----------------------------------------------------------------------------

model ChatMenuItem {
  id          String  @id @default(cuid())
  labelAr     String
  labelEn     String
  icon        String? // emoji or icon name
  linkUrl     String? // internal or external link
  parentId    String? // null = top-level, else = sub-item
  number      Int     @default(999)
  isHidden    Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([isHidden])
}

