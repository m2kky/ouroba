// This is your Prisma schema file
// Configured for PostgreSQL on a VPS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Users & Authentication
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Admin Credentials login
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  cartItems     CartItem[]
}

enum Role {
  USER
  ADMIN
}

// -----------------------------------------------------------------------------
// Main Entities (Products, Brands, Recipes)
// -----------------------------------------------------------------------------

model Brand {
  id             String   @id @default(cuid())
  nameEn         String
  nameAr         String
  number         Int      @default(0)
  imageBrand     String?
  imageSmall     String?
  imageMain      String?
  imageSmallMain String?
  colorBrand     String?
  colorHover     String?
  descriptionEn  String?  @db.Text
  descriptionAr  String?  @db.Text
  isHidden       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations if needed
  // products Product[]
}

model ProductType {
  id        String    @id @default(cuid())
  nameEn    String
  nameAr    String
  image     String?
  isHidden  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Category {
  id          String    @id @default(cuid())
  nameEn      String
  nameAr      String
  slug        String    @unique
  description String?
  imageUrl    String?
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

model Product {
  id            String    @id @default(cuid())
  nameEn        String
  nameAr        String
  number        Int       @default(0)
  descriptionEn String?   @db.Text
  descriptionAr String?   @db.Text
  image         String?
  color         String?
  price         Float     @default(0.0) // Kept for B2B inquiry/reference
  stock         Int       @default(0)   // Kept for B2B inquiry/reference
  isHidden      Boolean   @default(false)
  
  typeId        String?
  categoryId    String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  type          ProductType?    @relation(fields: [typeId], references: [id])
  category      Category?       @relation(fields: [categoryId], references: [id])
  socials       ProductSocial[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  recipes       Recipe[]        // Implicit many-to-many
}

model RecipeCategory {
  id        String   @id @default(cuid())
  titleEn   String
  titleAr   String
  number    Int      @default(0)
  image     String?
  isHidden  Boolean  @default(false)
  
  parentId  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    RecipeCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children  RecipeCategory[] @relation("SubCategories")
  recipes   Recipe[]
}

model Recipe {
  id              String   @id @default(cuid())
  nameEn          String
  nameAr          String
  number          Int      @default(0)
  imageMain       String?
  imageInternal   String?
  videoLink       String?
  descriptionEn   String?  @db.Text
  descriptionAr   String?  @db.Text
  isHidden        Boolean  @default(false)
  
  categoryId      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        RecipeCategory? @relation(fields: [categoryId], references: [id])
  relatedProducts Product[]       // Implicit many-to-many
}

// -----------------------------------------------------------------------------
// Site Content & Marketing
// -----------------------------------------------------------------------------

model Slider {
  id             String     @id @default(cuid())
  titleEn        String
  titleAr        String
  number         Int        @default(0)
  type           BannerType @default(IMAGE)
  fileImage      String?
  fileSmallImage String?
  fileVideo      String?
  fileSmallVideo String?
  isHidden       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum BannerType {
  IMAGE
  VIDEO
}

model Certificate {
  id        String   @id @default(cuid())
  image     String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Standard {
  id            String   @id @default(cuid())
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Value {
  id            String   @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhyChooseUs {
  id            String   @id @default(cuid())
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Building {
  id            String   @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Feature {
  id            String   @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductionStep {
  id        String   @id @default(cuid())
  textEn    String   @db.Text
  textAr    String   @db.Text
  number    Int      @default(0)
  image     String?
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionText {
  id        String   @id @default(cuid())
  titleEn   String
  titleAr   String
  textEn    String   @db.Text
  textAr    String   @db.Text
  number    Int      @default(0)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  image     String?
  link      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSocial {
  id        String   @id @default(cuid())
  image     String?
  productId String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEn     String   @db.Text
  valueAr     String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Geography
// -----------------------------------------------------------------------------

model Continent {
  id        String    @id @default(cuid())
  nameEn    String
  nameAr    String
  isHidden  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  countries Country[]
}

model Country {
  id          String    @id @default(cuid())
  nameEn      String
  nameAr      String
  continentId String
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  continent   Continent @relation(fields: [continentId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Lead Generation (Forms)
// -----------------------------------------------------------------------------

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?       @db.Text
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CareerRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  position  String?
  resumeUrl String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CollaborateRequest {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

enum RequestStatus {
  UNREAD
  READ
  ARCHIVED
}

// -----------------------------------------------------------------------------
// B2B Inquiry Models (Formerly E-commerce)
// -----------------------------------------------------------------------------

model CartItem {
  id        String   @id @default(cuid())
  sessionId String   
  userId    String?
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, productId])
}

// Orders act as the submitted B2B Inquiry form
model Order {
  id          String      @id @default(cuid())
  userId      String?     
  status      OrderStatus @default(PENDING)
  totalAmount Float       // Can be 0 for a generic inquiry without pricing
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float    // Can be 0 for an inquiry
  
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
