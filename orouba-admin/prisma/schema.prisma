generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role       @default(USER)
  permissions   String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  cartItems     CartItem[]
  orders        Order[]
}

model Brand {
  id             String        @id @default(cuid())
  nameEn         String
  nameAr         String
  number         Int           @default(999)
  image          String?
  imageMain      String?
  imageSmall     String?
  imageSmallMain String?
  colorBrand     String?
  colorHover     String?
  descriptionEn  String?
  descriptionAr  String?
  brandTextEn    String?
  brandTextAr    String?
  isHidden       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categories     Category[]
  foods          Food[]
  productTypes   ProductType[]

  @@index([isHidden])
}

model CategoryType {
  id            String                 @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String?
  descriptionAr String?
  image         String?
  number        Int                    @default(999)
  isHidden      Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  categories    CategoryTypeCategory[]

  @@index([isHidden])
}

model Category {
  id            String                 @id @default(cuid())
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  image         String?
  imageEn       String?
  number        Int                    @default(999)
  isHidden      Boolean                @default(false)
  brandId       String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  brand         Brand                  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  products      CategoryProduct[]
  categoryTypes CategoryTypeCategory[]

  @@index([isHidden])
  @@index([brandId])
}

model CategoryTypeCategory {
  id             String       @id @default(cuid())
  categoryId     String
  categoryTypeId String
  image          String?
  number         Int          @default(999)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryType   CategoryType @relation(fields: [categoryTypeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, categoryTypeId])
}

model ProductType {
  id        String    @id @default(cuid())
  nameEn    String
  nameAr    String
  number    Int       @default(999)
  brandId   String?
  isHidden  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  brand     Brand?    @relation(fields: [brandId], references: [id])
  products  Product[]

  @@index([isHidden])
  @@index([brandId])
}

model Product {
  id                 String              @id @default(cuid())
  nameEn             String
  nameAr             String
  descriptionEn      String?
  descriptionAr      String?
  color              String              @default("#ffffff")
  number             Int                 @default(999)
  isHidden           Boolean             @default(false)
  typeId             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cartItems          CartItem[]
  categories         CategoryProduct[]
  orderItems         OrderItem[]
  type               ProductType?        @relation(fields: [typeId], references: [id])
  images             ProductImage[]
  socials            ProductSocial[]
  recommendedRecipes RecommendedRecipe[]

  @@index([isHidden])
  @@index([typeId])
}

model CategoryProduct {
  id         String   @id @default(cuid())
  categoryId String
  productId  String
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([categoryId, productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RecipeCategory {
  id        String               @id @default(cuid())
  nameEn    String
  nameAr    String
  image     String?
  number    Int                  @default(999)
  isHidden  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  foods     RecipeCategoryFood[]
}

model Recipe {
  id              String              @id @default(cuid())
  nameEn          String?
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  videoLink       String?
  internalImage   String?
  number          Int                 @default(999)
  isHidden        Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tagAr           String?
  tagEn           String?
  foods           RecipeFood[]
  images          RecipeImage[]
  properties      RecipeProperty[]
  steps           RecipeStep[]
  recommendedWith RecommendedRecipe[]

  @@index([isHidden])
}

model RecipeImage {
  id        String   @id @default(cuid())
  recipeId  String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeProperty {
  id        String   @id @default(cuid())
  recipeId  String
  icon      String?
  titleEn   String
  titleAr   String
  textEn    String
  textAr    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeStep {
  id        String   @id @default(cuid())
  recipeId  String
  stepEn    String
  stepAr    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Food {
  id               String               @id @default(cuid())
  nameEn           String?
  nameAr           String?
  image            String?
  number           Int                  @default(999)
  brandId          String?
  isHidden         Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  brand            Brand?               @relation(fields: [brandId], references: [id])
  recipeCategories RecipeCategoryFood[]
  recipes          RecipeFood[]

  @@index([isHidden])
  @@index([brandId])
}

model RecipeFood {
  id        String   @id @default(cuid())
  recipeId  String
  foodId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, foodId])
}

model RecipeCategoryFood {
  id               String         @id @default(cuid())
  recipeCategoryId String
  foodId           String
  food             Food           @relation(fields: [foodId], references: [id], onDelete: Cascade)
  recipeCategory   RecipeCategory @relation(fields: [recipeCategoryId], references: [id], onDelete: Cascade)

  @@unique([recipeCategoryId, foodId])
}

model RecommendedRecipe {
  id        String   @id @default(cuid())
  productId String
  recipeId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([productId, recipeId])
}

model Banner {
  id           String     @id @default(cuid())
  titleEn      String
  titleAr      String
  type         BannerType @default(image)
  image        String?
  imageEn      String?
  videoLink    String?
  videoLinkEn  String?
  smallImg     String?
  smallImgEn   String?
  smallVideo   String?
  smallVideoEn String?
  number       Int        @default(999)
  isHidden     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([isHidden])
}

model Certificate {
  id        String   @id @default(cuid())
  image     String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Standard {
  id            String   @id @default(cuid())
  descriptionEn String
  descriptionAr String
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Value {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?
  descriptionAr String?
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhyChooseUs {
  id            String   @id @default(cuid())
  descriptionEn String
  descriptionAr String
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Building {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?
  descriptionAr String?
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Feature {
  id            String   @id @default(cuid())
  titleEn       String?
  titleAr       String?
  descriptionEn String?
  descriptionAr String?
  image         String?
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductionStep {
  id        String   @id @default(cuid())
  textEn    String
  textAr    String
  number    Int      @default(999)
  image     String?
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionText {
  id        String   @id @default(cuid())
  titleEn   String?
  titleAr   String?
  textEn    String?
  textAr    String?
  number    Int      @default(999)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  image     String?
  link      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialParent {
  id        String   @id @default(cuid())
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSocial {
  id        String   @id @default(cuid())
  image     String?
  action    String?
  productId String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEn     String?
  valueAr     String?
  description String?
  updatedAt   DateTime @updatedAt
}

model Continent {
  id        String    @id @default(cuid())
  nameEn    String?
  nameAr    String?
  isHidden  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  countries Country[]
}

model Country {
  id          String    @id @default(cuid())
  nameEn      String?
  nameAr      String?
  continentId String
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  continent   Continent @relation(fields: [continentId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CareerRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  position  String?
  message   String?
  resumeUrl String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CollaborateRequest {
  id        String        @id @default(cuid())
  firstName String?
  lastName  String?
  name      String?
  email     String
  phone     String?
  message   String?
  status    RequestStatus @default(UNREAD)
  createdAt DateTime      @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, productId])
}

model Order {
  id          String      @id @default(cuid())
  userId      String?
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float   @default(0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model SystemLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String?
  date      String?
  ip        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Popup {
  id              String    @id @default(cuid())
  internalName    String
  titleEn         String?
  titleAr         String?
  contentEn       String?
  contentAr       String?
  image           String?
  type            String    @default("MODAL")
  animation       String    @default("FADE")
  backgroundColor String    @default("#ffffff")
  textColor       String    @default("#000000")
  overlayColor    String    @default("rgba(0,0,0,0.5)")
  borderRadius    Int       @default(16)
  maxWidth        Int       @default(500)
  buttons         Json?
  trigger         String    @default("ON_LOAD")
  triggerValue    Int       @default(0)
  conditions      Json?
  isActive        Boolean   @default(false)
  priority        Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ChatMenuItem {
  id        String   @id @default(cuid())
  labelAr   String
  labelEn   String
  icon      String?
  linkUrl   String?
  parentId  String?
  number    Int      @default(999)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isHidden])
}

enum Role {
  USER
  ADMIN
  EDITOR
}

enum BannerType {
  image
  video
}

enum RequestStatus {
  UNREAD
  READ
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
